{
  "name": "openpress",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OpenPress — A modern, edge-native, open-source CMS and web application platform",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "dev:full": "wrangler pages dev -- npm run dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "pages:deploy": "npm run build && wrangler pages deploy dist",
    "db:migrate": "wrangler d1 execute openpress-db --file=./schema/001_initial.sql",
    "db:migrate:local": "wrangler d1 execute openpress-db --local --file=./schema/001_initial.sql"
  },
  "dependencies": {
    "@blocknote/core": "^0.47.3",
    "@blocknote/react": "^0.47.3",
    "@blocknote/server-util": "^0.47.3",
    "@tanstack/react-router": "^1.120.0",
    "clsx": "^2.1.0",
    "hono": "^4.7.0",
    "jose": "^6.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250303.0",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "happy-dom": "^17.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0",
    "wrangler": "^4.14.0"
  }
}
